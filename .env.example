# Hylyx Build & Deploy Configuration
# Copy to .env and fill in your values

# Apple Developer credentials (for code signing & notarization)
APPLE_ID="your@email.com"
NOTARIZE_PASSWORD="xxxx-xxxx-xxxx-xxxx"  # App-specific password from appleid.apple.com
TEAM_ID="XXXXXXXXXX"                      # Developer Team ID

# Cloud URL (used by binary for image downloads)
CLOUD="https://your.domain.com/hylyx"